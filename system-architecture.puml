@startuml

skinparam backgroundColor white
skinparam defaultFontName "Microsoft YaHei"
skinparam defaultFontSize 12
skinparam componentStyle rectangle

' 左侧：数据与智能基座
package "数据与智能基座" #FFF4E6 {
  database "百万级\n招聘语料" as DB1 #BBDEFB
  database "AEI\n公开数据集" as DB2 #BBDEFB
  database "Qdrant\n向量库" as DB3 #BBDEFB
}

' 上方：用户交互层
rectangle "用户交互层 · 七大功能模块" as FuncLayer #E8F5E9 {
  component "能力画像" as F1 #DBEAFE
  component "JD诊断" as F2 #D1FAE5
  component "知识图谱" as F3 #FEF3C7
  component "发展报告" as F4 #FCE7F3
  component "成长档案" as F5 #FEE2E2
  component "模拟面试" as F6 #FED7AA
  component "AI教练" as F7 #BFDBFE

  F1 -[hidden]right- F2
  F2 -[hidden]right- F3
  F3 -[hidden]right- F4
  F4 -[hidden]right- F5
  F5 -[hidden]right- F6
  F6 -[hidden]right- F7
}

' 下方：核心流程层
rectangle "核心流程层 · 五步闭环\n\n\n\n\n\n能力评估反馈" as FlowLayer #F3E5F5 {
  usecase "1. 画像构建" as S1 #67E8F9
  usecase "2. 人岗匹配" as S2 #86EFAC
  usecase "3. 报告生成" as S3 #FDE68A
  usecase "4. 成长档案" as S4 #86EFAC
  usecase "5. 模拟面试" as S5 #FB923C

  S1 -[hidden]right- S2
  S2 -[hidden]right- S3
  S3 -[hidden]right- S4
  S4 -[hidden]right- S5
}

' 数据层 → 功能层
DB1 ..> F1
DB2 ..> F2
DB3 ..> F3

' 功能层 → 流程层
F1 ..> S1
F2 ..> S2
F3 ..> S2
F4 ..> S3
F5 ..> S4
F6 ..> S5
F7 ..> S5

' 流程节点连接
S1 --> S2
S2 --> S3
S3 --> S4
S4 --> S5
S5 ..> S1

@enduml
