# =========================
# 核心鉴权
# =========================

# DashScope API Key（必填）- 阿里云百炼平台
# 获取地址：https://dashscope.aliyuncs.com/
DASHSCOPE_API_KEY=sk-your-api-key-here

# DashScope 兼容模式地址（可选，默认值如下）
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# JWT 签名密钥（必填）- 用于用户登录令牌
# 生产环境请更换为随机长字符串
JWT_SECRET_KEY=change-me-in-production

# =========================
# 外部 API Key（可选）
# =========================

# Tavily 搜索 API - 用于联网搜索岗位信息
# 获取地址：https://tavily.com/
TAVILY_API_KEY=tvly-dev-your-key-here

# Firecrawl API - 用于网页抓取
# 获取地址：https://firecrawl.dev/
FIRECRAWL_API_KEY=fc-your-key-here

# =========================
# 简历解析（可选）
# =========================

# ResumeSDK — 阿里云市场版简历解析
# 购买链接：https://market.aliyun.com/detail/cmapi034316
# RESUMESDK_APPCODE=your-appcode
# RESUMESDK_APPKEY=your-appkey
# RESUMESDK_APPSECRET=your-appsecret
# RESUMESDK_BASE_URL=https://resumesdk.market.alicloudapi.com/ResumeParser

# =========================
# 语音服务（可选）
# =========================

# 讯飞语音 — 用于语音输入/输出
# 获取地址：https://console.xfyun.cn/
# XFYUN_APP_ID=your-app-id
# XFYUN_API_KEY=your-api-key
# XFYUN_API_SECRET=your-api-secret

# =========================
# 模型配置（可选）
# =========================

# 注意：不要设置 LLM_MODEL，代码内置了 qwen-plus (fast) / qwen-max (strong) 的自动映射
# 手动设置会覆盖所有用途，可能导致超时

# 嵌入模型（可选，默认 text-embedding-v4）
# EMBEDDING_MODEL=text-embedding-v4

# =========================
# PDF 导出（可选）
# =========================

# PDF_EXPORT_ENGINE=playwright
# PDF_EXPORT_TIMEOUT_SECONDS=60
# PDF_EXPORT_PAGE_FORMAT=A4
# PDF_EXPORT_LOCALE=zh-CN
# PDF_EXPORT_FALLBACK_TO_REPORTLAB=true

# =========================
# 前端地址（可选）
# =========================

# 用于 CORS 白名单，默认 http://localhost:5174
# FRONTEND_URL=http://localhost:5174
