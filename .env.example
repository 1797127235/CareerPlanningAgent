# 环境变量配置文件
# 请将此文件重命名为 .env 并填入真实的API Key

# 阿里云百炼 API Key（必需）
# 获取地址: https://dashscope.aliyun.com/
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here
# 如果使用子账号/指定工作空间，可补充 workspace ID（可选）
# DASHSCOPE_WORKSPACE_ID=ws_your_dashscope_workspace_id

# ── 向量数据库配置 ──
# 后端选择: qdrant (默认) 或 chroma
# VECTOR_DB=qdrant

# Qdrant 模式: local (嵌入式，默认) 或 server (Docker/远程服务)
# QDRANT_MODE=local
# QDRANT_HOST=localhost
# QDRANT_PORT=6333

# HNSW 索引参数（针对 ~10K 条 1024 维向量优化）
# HNSW_M=32
# HNSW_EF_CONSTRUCT=256
# HNSW_EF_SEARCH=128

# ── JD 搜索（Firecrawl）──
# 获取地址: https://www.firecrawl.dev/
FIRECRAWL_API_KEY=fc-your-key-here

# ── 讯飞语音（语言面试 STT/TTS）──
# 获取地址: https://console.xfyun.cn/
XFYUN_APP_ID=your_app_id
XFYUN_API_KEY=your_api_key
XFYUN_API_SECRET=your_api_secret
# TTS_PROVIDER=minimax   # 切换到 MiniMax T2A（需自行实现 _run_tts_minimax）

# ── 可选配置 ──
# LLM_MODEL=qwen-plus
# EMBEDDING_MODEL=text-embedding-v4
# RERANK_MODEL=qwen3-rerank
# INTERVIEW_GEN_MODEL=qwen-plus   # 出题专用模型，默认 qwen-plus（高推理能力）
