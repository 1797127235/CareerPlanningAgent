# =============================================================================
# 职途智析 生产环境配置模板
# 复制此文件为 .env 并填入真实值后部署
# 文件权限必须设为 600 (chmod 600 .env)
# =============================================================================

# ── 必选：JWT 密钥 ──────────────────────────────────────────────────────────
# 生成方式: openssl rand -hex 32
# 警告：此密钥泄露 = 任何人可伪造登录态
JWT_SECRET_KEY=

# ── 必选：LLM API (阿里云 DashScope) ───────────────────────────────────────
DASHSCOPE_API_KEY=sk-
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── 可选：CORS (前端域名) ───────────────────────────────────────────────────
# 生产环境必须限制为你的域名，不要用 *
CORS_ORIGINS=http://localhost:5173

# ── 可选：ResumeSDK (简历解析) ─────────────────────────────────────────────
RESUMESDK_ENABLED=false
RESUMESDK_APPCODE=
RESUMESDK_APPKEY=
RESUMESDK_APPSECRET=
RESUMESDK_UID=
RESUMESDK_PWD=

# ── 可选：Mem0 模型配置 ─────────────────────────────────────────────────────
MEM0_LLM_MODEL=qwen-plus
MEM0_EMBEDDING_MODEL=text-embedding-v3

# ── 环境标识 ─────────────────────────────────────────────────────────────────
ENV=production
